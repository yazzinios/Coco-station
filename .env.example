# Database mode: "local" or "cloud"
DB_MODE=local

# Local PostgreSQL
POSTGRES_USER=coco
POSTGRES_PASSWORD=coco_secret
POSTGRES_DB=cocostation

# Cloud Supabase (fill when DB_MODE=cloud)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-publishable-key-here

# MediaMTX
MEDIAMTX_HOST=mediamtx
